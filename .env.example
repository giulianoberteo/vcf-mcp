FLEET_BASE_URL=https://your-fleet-management-host
FLEET_USER=admin@local
FLEET_PASSWORD=your-fleet-password

VCFOPS_BASE_URL=https://your-vcf-ops-host
VCFOPS_USER=your-vcf-ops-username
VCFOPS_PASSWORD=your-vcf-ops-password
# Optional; only needed for LDAP users — set to the exact auth source name
# shown in Aria Ops Administration > Auth Sources.
VCFOPS_AUTH_SOURCE=

SDDC_BASE_URL=https://your-sddc-manager-host
SDDC_USER=administrator@vsphere.local
SDDC_PASSWORD=your-sddc-password

# Optional, default false — lab VCF instances typically run self-signed
# certs. Set to "true" to enforce TLS certificate verification.
FLEET_VERIFY_SSL=false
VCFOPS_VERIFY_SSL=false
SDDC_VERIFY_SSL=false

# Optional, default 30
API_TIMEOUT_SECONDS=30
